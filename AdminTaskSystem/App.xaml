<Application x:Class="AdminTaskSystem.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:AdminTaskSystem.Converters"
             xmlns:vm="clr-namespace:AdminTaskSystem.ViewModels"
             xmlns:views="clr-namespace:AdminTaskSystem.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Blue" SecondaryColor="DeepOrange" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="SidebarBg">#1A3A5C</Color>
            <Color x:Key="SidebarActiveBg">#1E4E7A</Color>
            <Color x:Key="SidebarBorderC">#162F4A</Color>
            <Color x:Key="SidebarTextC">#B8CDE0</Color>
            <Color x:Key="AccentBlue">#1565C0</Color>
            <Color x:Key="AccentOrange">#E65100</Color>
            <Color x:Key="ContentBg">#F4F6F9</Color>
            <Color x:Key="CardBg">#FFFFFF</Color>
            <Color x:Key="BorderC">#DDE3EC</Color>
            <Color x:Key="TextPrimary">#1A2B3C</Color>
            <Color x:Key="TextSecondary">#6B7D8F</Color>
            <Color x:Key="TextMuted">#9BAAB8</Color>
            <Color x:Key="RowAlt">#F8F9FC</Color>
            <Color x:Key="RowHover">#EFF6FF</Color>
            <Color x:Key="RowOverdue">#FFF5F5</Color>
            <Color x:Key="RowWarning">#FFFBF0</Color>

            <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBg}" />
            <SolidColorBrush x:Key="SidebarActiveBgBrush" Color="{StaticResource SidebarActiveBg}" />
            <SolidColorBrush x:Key="SidebarBorderCBrush" Color="{StaticResource SidebarBorderC}" />
            <SolidColorBrush x:Key="SidebarTextCBrush" Color="{StaticResource SidebarTextC}" />
            <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}" />
            <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}" />
            <SolidColorBrush x:Key="ContentBgBrush" Color="{StaticResource ContentBg}" />
            <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}" />
            <SolidColorBrush x:Key="BorderCBrush" Color="{StaticResource BorderC}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
            <SolidColorBrush x:Key="RowAltBrush" Color="{StaticResource RowAlt}" />
            <SolidColorBrush x:Key="RowHoverBrush" Color="{StaticResource RowHover}" />
            <SolidColorBrush x:Key="RowOverdueBrush" Color="{StaticResource RowOverdue}" />
            <SolidColorBrush x:Key="RowWarningBrush" Color="{StaticResource RowWarning}" />

            <conv:StatusBrushConverter x:Key="StatusBrushConverter" />
            <conv:StatusFgConverter x:Key="StatusFgConverter" />
            <conv:StatusCaptionConverter x:Key="StatusCaptionConverter" />
            <conv:DeadlineFlagBrushConverter x:Key="DeadlineFlagBrushConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <conv:RoleBadgeColorConverter x:Key="RoleBadgeColorConverter" />

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Style>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="13" />
            </Style>
            <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="13" />
            </Style>
            <Style TargetType="PasswordBox">
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="13" />
            </Style>
            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="Padding" Value="12,6" />
            </Style>
            <Style TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="13" />
            </Style>
            <Style TargetType="DataGrid">
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Background" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderCBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="GridLinesVisibility" Value="Horizontal" />
                <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderCBrush}" />
                <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
                <Setter Property="RowHeaderWidth" Value="0" />
            </Style>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#F8FAFC" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderCBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
            </Style>
            <Style TargetType="DataGridCell">
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            </Style>
            <Style TargetType="DataGridRow">
                <Setter Property="MinHeight" Value="40" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderCBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
            </Style>

            <DataTemplate DataType="{x:Type vm:ProfileViewModel}"><views:ProfileView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:TicketsViewModel}"><views:TicketsView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:TasksViewModel}"><views:TasksView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:EmployeesViewModel}"><views:EmployeesView /></DataTemplate>
            <DataTemplate DataType="{x:Type vm:ReportsViewModel}"><views:ReportsView /></DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
