<UserControl x:Class="AdminTaskSystem.Views.TicketsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel Margin="24">
        <materialDesign:Snackbar DockPanel.Dock="Bottom" MessageQueue="{Binding MessageQueue}" />

        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Заявки отдела" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Сотрудник видит все заявки своего отдела и может принять свободную заявку в работу"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding ExportToExcelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Padding="14,8"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileExcelOutline" Width="18" Height="18" Margin="0,0,7,0" />
                        <TextBlock Text="Экспорт" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <UniformGrid DockPanel.Dock="Top" Columns="5" Height="92" Margin="0,0,0,14">
            <Border Background="White" BorderBrush="{StaticResource BorderCBrush}" BorderThickness="1" CornerRadius="12" Margin="0,0,10,0" Padding="16">
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="42" Height="42" CornerRadius="12" Background="#E3F2FD" Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="ClipboardTextOutline" Foreground="#1565C0" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Все заявки" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding TotalCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource BorderCBrush}" BorderThickness="1" CornerRadius="12" Margin="0,0,10,0" Padding="16">
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="42" Height="42" CornerRadius="12" Background="#FFF3E0" Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="ProgressClock" Foreground="#E65100" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="В работе" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding InProgressCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource BorderCBrush}" BorderThickness="1" CornerRadius="12" Margin="0,0,10,0" Padding="16">
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="42" Height="42" CornerRadius="12" Background="#E8F5E9" Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="#2E7D32" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Выполнено" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding DoneCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource BorderCBrush}" BorderThickness="1" CornerRadius="12" Margin="0,0,10,0" Padding="16">
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="42" Height="42" CornerRadius="12" Background="#FFEBEE" Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#C62828" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Просрочено" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding OverdueCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource BorderCBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="42" Height="42" CornerRadius="12" Background="#E8EAF6" Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="AccountCheckOutline" Foreground="#1A3A5C" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Мои заявки" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding MyTicketsCount}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </UniformGrid>

        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="{StaticResource BorderCBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,0,12"
                Visibility="{Binding CanUseFilters, Converter={StaticResource BoolToVisibilityConverter}}">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="Фильтры"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,14,0" />
                <ComboBox ItemsSource="{Binding StatusFilters}"
                          SelectedItem="{Binding SelectedStatusFilter}"
                          Width="160"
                          Margin="0,0,10,0"
                          materialDesign:HintAssist.Hint="Статус" />
                <ComboBox ItemsSource="{Binding CategoryFilters}"
                          SelectedItem="{Binding SelectedCategoryFilter}"
                          Width="200"
                          Margin="0,0,10,0"
                          materialDesign:HintAssist.Hint="Категория" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Width="310"
                         materialDesign:HintAssist.Hint="Поиск по теме или заявителю"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="Magnify" />
                <CheckBox Content="Только мои заявки"
                          IsChecked="{Binding ShowOnlyMyTickets}"
                          VerticalAlignment="Center"
                          Margin="18,0,0,0"
                          />
            </WrapPanel>
        </Border>

        <ProgressBar DockPanel.Dock="Top"
                     Height="3"
                     IsIndeterminate="True"
                     Margin="0,0,0,0"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />

        <Border Background="White"
                BorderBrush="{StaticResource BorderCBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <DataGrid x:Name="Grid"
                          ItemsSource="{Binding FilteredTickets}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          BorderThickness="0"
                          Background="White"
                          AlternatingRowBackground="{StaticResource RowAltBrush}"
                          MouseDoubleClick="Grid_OnMouseDoubleClick">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{Binding DeadlineFlag, Converter={StaticResource DeadlineFlagBrushConverter}}" />
                            <Setter Property="MinHeight" Value="46" />
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="58" />
                        <DataGridTemplateColumn Header="Тема" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="LockOutline"
                                                                 Width="14"
                                                                 Height="14"
                                                                 Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                 Margin="0,2,6,0"
                                                                 Foreground="{StaticResource AccentOrangeBrush}" />
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="125" />
                        <DataGridTextColumn Header="Отдел" Binding="{Binding DepartmentName}" Width="150" />
                        <DataGridTextColumn Header="Исполнитель" Binding="{Binding AssignedEmployeeName, TargetNullValue=Не назначен}" Width="150" />
                        <DataGridTemplateColumn Header="Статус" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            Padding="9,3"
                                            HorizontalAlignment="Left"
                                            Background="{Binding Status, Converter={StaticResource StatusBrushConverter}}">
                                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusCaptionConverter}}"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusFgConverter}}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Дедлайн" Binding="{Binding Deadline, StringFormat={}{0:dd.MM.yyyy}}" Width="110" />
                        <DataGridTemplateColumn Header="Действия" Width="132">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding DataContext.AcceptTicketCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                Padding="8,2"
                                                ToolTip="Принять заявку в работу"
                                                Visibility="{Binding CanAccept, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="#2E7D32" Width="18" Height="18" Margin="0,0,4,0" />
                                                <TextBlock Text="Принять" Foreground="#2E7D32" FontSize="12" />
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding DataContext.OpenTicketCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignToolButton}"
                                                ToolTip="Открыть карточку">
                                            <materialDesign:PackIcon Kind="EyeOutline" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasTickets, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="ClipboardTextOffOutline"
                                             Width="54"
                                             Height="54"
                                             Foreground="{StaticResource TextMutedBrush}"
                                             HorizontalAlignment="Center" />
                    <TextBlock Text="Заявки не найдены"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,10,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
