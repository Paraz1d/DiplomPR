<UserControl x:Class="AdminTaskSystem.Views.ProfileView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel Margin="24">
        <materialDesign:Snackbar DockPanel.Dock="Bottom" MessageQueue="{Binding MessageQueue}" />
        <TextBlock DockPanel.Dock="Top" Text="Профиль сотрудника" FontSize="16" FontWeight="Medium" Margin="0,0,0,16" />
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="{StaticResource BorderCBrush}" BorderThickness="1" Padding="24" Margin="0,0,0,16">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="3*" /></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"><Border Width="72" Height="72" CornerRadius="36" Background="{StaticResource AccentBlueBrush}" Margin="0,0,16,0"><TextBlock Text="{Binding Initials}" Foreground="White" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><StackPanel><TextBlock Text="{Binding FullName}" FontSize="18" FontWeight="Medium" /><Border Background="{Binding Source={x:Static local:AppSession.CurrentUser}, Path=Role, Converter={StaticResource RoleBadgeColorConverter}}" xmlns:local="clr-namespace:AdminTaskSystem" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left" Margin="0,6"><TextBlock Text="{Binding RoleName}" Foreground="White" FontSize="11" /></Border><TextBlock Text="{Binding DepartmentName}" Foreground="{StaticResource TextSecondaryBrush}" /><TextBlock Text="{Binding Email}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" /><TextBlock Text="{Binding Phone}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" /></StackPanel></StackPanel>
                <UniformGrid Grid.Column="1" Columns="5"><Border Padding="10" BorderBrush="#1565C0" BorderThickness="0,3,0,1" Margin="4"><StackPanel><TextBlock Text="Мои заявки" Foreground="{StaticResource TextSecondaryBrush}" /><TextBlock Text="{Binding MyTicketsTotal}" FontSize="20" /></StackPanel></Border><Border Padding="10" BorderBrush="#2E7D32" BorderThickness="0,3,0,1" Margin="4"><StackPanel><TextBlock Text="Выполнено" /><TextBlock Text="{Binding MyTicketsDone}" FontSize="20" /></StackPanel></Border><Border Padding="10" BorderBrush="#C62828" BorderThickness="0,3,0,1" Margin="4"><StackPanel><TextBlock Text="Просрочено" /><TextBlock Text="{Binding MyTicketsOverdue}" FontSize="20" /></StackPanel></Border><Border Padding="10" BorderBrush="#1565C0" BorderThickness="0,3,0,1" Margin="4"><StackPanel><TextBlock Text="Мои задачи" /><TextBlock Text="{Binding MyTasksTotal}" FontSize="20" /></StackPanel></Border><Border Padding="10" BorderBrush="#2E7D32" BorderThickness="0,3,0,1" Margin="4"><StackPanel><TextBlock Text="Задач готово" /><TextBlock Text="{Binding MyTasksDone}" FontSize="20" /></StackPanel></Border></UniformGrid>
            </Grid>
        </Border>
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="{StaticResource BorderCBrush}" BorderThickness="1" Padding="24" Margin="0,0,0,16"><StackPanel><TextBlock Text="Изменить пароль" FontSize="14" FontWeight="Medium" Margin="0,0,0,12" /><PasswordBox x:Name="CurrentPasswordBox" PasswordChanged="CurrentPasswordBox_OnPasswordChanged" Margin="0,0,0,8" /><PasswordBox x:Name="NewPasswordBox" PasswordChanged="NewPasswordBox_OnPasswordChanged" Margin="0,0,0,8" /><PasswordBox x:Name="ConfirmPasswordBox" PasswordChanged="ConfirmPasswordBox_OnPasswordChanged" Margin="0,0,0,12" /><Button Content="Сохранить пароль" Command="{Binding SavePasswordCommand}" HorizontalAlignment="Right" /></StackPanel></Border>
        <TextBlock Text="{Binding CacheStatus}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" />
    </DockPanel>
</UserControl>
