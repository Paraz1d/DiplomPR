<UserControl x:Class="AdminTaskSystem.Views.EmployeesView" 
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel Margin="20">
        <materialDesign:Snackbar DockPanel.Dock="Bottom" MessageQueue="{Binding MessageQueue}" />
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Сотрудники" FontSize="16" FontWeight="Medium" />
        </DockPanel>
        <TextBox DockPanel.Dock="Top" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Поиск" Margin="0,0,0,10" /><DataGrid ItemsSource="{Binding Employees}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" AlternatingRowBackground="{StaticResource RowAltBrush}"><DataGrid.Columns><DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*" /><DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" /><DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*" /><DataGridTextColumn Header="Отдел" Binding="{Binding DepartmentName}" Width="*" /><DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="110" /><DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="90" /><DataGridTemplateColumn Header="Actions" Width="100"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal"><Button Command="{Binding DataContext.EditEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignToolButton}"><materialDesign:PackIcon Kind="Pencil" /></Button><Button Command="{Binding DataContext.DeactivateEmployeeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignToolButton}" Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}"><materialDesign:PackIcon Kind="Power" /></Button></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn></DataGrid.Columns></DataGrid></DockPanel></UserControl>
