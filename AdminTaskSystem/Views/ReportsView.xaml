<UserControl x:Class="AdminTaskSystem.Views.ReportsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"><DockPanel Margin="20"><materialDesign:Snackbar DockPanel.Dock="Bottom" MessageQueue="{Binding MessageQueue}" /><DockPanel DockPanel.Dock="Top" Margin="0,0,0,12"><TextBlock Text="Отчёты" FontSize="16" FontWeight="Medium" /><Button DockPanel.Dock="Right" Content="Export" Command="{Binding ExportCommand}" Background="#2E7D32" Foreground="White" Visibility="{Binding CanExport, Converter={StaticResource BoolToVisibilityConverter}}" /></DockPanel><WrapPanel DockPanel.Dock="Top" Margin="0,0,0,12"><TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,4,0" /><DatePicker SelectedDate="{Binding DateFrom}" Width="140" Margin="0,0,8,0" /><TextBlock Text="По:" VerticalAlignment="Center" Margin="0,0,4,0" /><DatePicker SelectedDate="{Binding DateTo}" Width="140" Margin="0,0,8,0" /><Button Content="Применить" Command="{Binding LoadCommand}" /></WrapPanel><UniformGrid DockPanel.Dock="Top" Columns="4" Height="80" Margin="0,0,0,12"><Border Background="White" BorderBrush="#1565C0" BorderThickness="0,3,0,1" Margin="0,0,8,0" Padding="12"><StackPanel><TextBlock Text="Всего заявок" /><TextBlock Text="{Binding TotalTickets}" FontSize="22" /></StackPanel></Border><Border Background="White" BorderBrush="#2E7D32" BorderThickness="0,3,0,1" Margin="0,0,8,0" Padding="12"><StackPanel><TextBlock Text="Выполнено" /><TextBlock Text="{Binding TotalDone}" FontSize="22" /></StackPanel></Border><Border Background="White" BorderBrush="#C62828" BorderThickness="0,3,0,1" Margin="0,0,8,0" Padding="12"><StackPanel><TextBlock Text="Просрочено" /><TextBlock Text="{Binding TotalOverdue}" FontSize="22" /></StackPanel></Border><Border Background="White" BorderBrush="#E65100" BorderThickness="0,3,0,1" Padding="12"><StackPanel><TextBlock Text="Среднее время (ч)" /><TextBlock Text="{Binding AvgCloseHours, StringFormat={}{0:N1}}" FontSize="22" /></StackPanel></Border></UniformGrid><TabControl><TabItem Header="По отделам"><DataGrid ItemsSource="{Binding DeptStats}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"><DataGrid.Columns><DataGridTextColumn Header="Отдел" Binding="{Binding Department}" Width="2*" /><DataGridTextColumn Header="Всего" Binding="{Binding Total}" Width="*" /><DataGridTextColumn Header="Новые" Binding="{Binding NewCount}" Width="*" /><DataGridTextColumn Header="В работе" Binding="{Binding InProgressCount}" Width="*" /><DataGridTextColumn Header="Выполнено" Binding="{Binding DoneCount}" Width="*" /><DataGridTextColumn Header="Просрочено" Binding="{Binding OverdueCount}" Width="*" /><DataGridTextColumn Header="Ср.время(ч)" Binding="{Binding AvgCloseHours}" Width="*" /></DataGrid.Columns></DataGrid></TabItem><TabItem Header="По сотрудникам"><DataGrid ItemsSource="{Binding EmpStats}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"><DataGrid.Columns><DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*" /><DataGridTextColumn Header="Отдел" Binding="{Binding Department}" Width="*" /><DataGridTextColumn Header="Заявок всего" Binding="{Binding TicketsTotal}" Width="*" /><DataGridTextColumn Header="Выполнено" Binding="{Binding TicketsDone}" Width="*" /><DataGridTextColumn Header="Просрочено" Binding="{Binding TicketsOverdue}" Width="*" /><DataGridTextColumn Header="Задач всего" Binding="{Binding TasksTotal}" Width="*" /><DataGridTextColumn Header="Выполнено" Binding="{Binding TasksDone}" Width="*" /></DataGrid.Columns></DataGrid></TabItem></TabControl></DockPanel></UserControl>
