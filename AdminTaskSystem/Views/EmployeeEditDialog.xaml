<UserControl x:Class="AdminTaskSystem.Views.EmployeeEditDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" Width="520" Background="White"><DockPanel><Border DockPanel.Dock="Top" Background="{StaticResource AccentBlueBrush}" Padding="24,16"><TextBlock Text="{Binding HeaderTitle}" Foreground="White" FontSize="16" FontWeight="SemiBold" /></Border><StackPanel Margin="24"><TextBox Text="{Binding FullName}" materialDesign:HintAssist.Hint="ФИО *" Margin="0,0,0,10" /><TextBox Text="{Binding Email}" materialDesign:HintAssist.Hint="Email *" Margin="0,0,0,10" /><TextBox Text="{Binding Phone}" materialDesign:HintAssist.Hint="Телефон" Margin="0,0,0,10" /><ComboBox ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" DisplayMemberPath="Name" materialDesign:HintAssist.Hint="Отдел *" Margin="0,0,0,10" /><ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" materialDesign:HintAssist.Hint="Роль *" Margin="0,0,0,10" /><PasswordBox x:Name="PasswordBox" PasswordChanged="PasswordBox_OnPasswordChanged" Margin="0,0,0,10" /><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Отмена" Command="{Binding CloseCommand}" Margin="0,0,8,0" /><Button Content="Сохранить" Command="{Binding SaveCommand}" Background="{StaticResource AccentBlueBrush}" Foreground="White" /></StackPanel></StackPanel><materialDesign:Snackbar MessageQueue="{Binding MessageQueue}" /></DockPanel></UserControl>
