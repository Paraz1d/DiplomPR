<UserControl x:Class="AdminTaskSystem.Views.TicketDetailDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" MinWidth="640" MaxWidth="860" Background="White">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource AccentBlueBrush}" Padding="24,16"><DockPanel><Button DockPanel.Dock="Right" Content="✕" Command="{Binding CloseCommand}" Background="Transparent" Foreground="White" BorderThickness="0" /><StackPanel><TextBlock Text="{Binding HeaderTitle}" Foreground="White" FontSize="16" FontWeight="SemiBold" /><TextBlock Text="{Binding HeaderSubtitle}" Foreground="#B3FFFFFF" FontSize="11" /></StackPanel></DockPanel></Border>
        <Border DockPanel.Dock="Top" Background="#FFF3E0" Padding="12,6" Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVisibilityConverter}}"><TextBlock Text="🔒 Заявка назначена другому сотруднику и доступна только для чтения." Foreground="#E65100" /></Border>
        <TabControl Margin="20" MaxHeight="560">
            <TabItem Header="Данные заявки"><ScrollViewer><Grid Margin="0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBox Grid.Row="0" Grid.Column="0" Text="{Binding TicketTitle, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Тема *" IsEnabled="{Binding CanManage}" Margin="0,0,0,10" /><TextBox Grid.Row="1" Grid.Column="0" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Описание *" Height="80" AcceptsReturn="True" IsEnabled="{Binding CanManage}" Margin="0,0,0,10" /><ComboBox Grid.Row="2" Grid.Column="0" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name" materialDesign:HintAssist.Hint="Категория *" IsEnabled="{Binding CanManage}" Margin="0,0,0,10" /><TextBox Grid.Row="3" Grid.Column="0" Text="{Binding ApplicantName}" materialDesign:HintAssist.Hint="ФИО заявителя *" IsEnabled="{Binding CanManage}" Margin="0,0,0,10" /><TextBox Grid.Row="0" Grid.Column="2" Text="{Binding ApplicantContact}" materialDesign:HintAssist.Hint="Контакт" IsEnabled="{Binding CanManage}" Margin="0,0,0,10" /><TextBox Grid.Row="1" Grid.Column="2" Text="{Binding ApplicantAddress}" materialDesign:HintAssist.Hint="Адрес" IsEnabled="{Binding CanManage}" Margin="0,0,0,10" /><ComboBox Grid.Row="2" Grid.Column="2" ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" DisplayMemberPath="Name" materialDesign:HintAssist.Hint="Отдел" IsEnabled="{Binding IsAdmin}" Margin="0,0,0,10" /><ComboBox Grid.Row="3" Grid.Column="2" ItemsSource="{Binding AvailableEmployees}" SelectedItem="{Binding SelectedEmployee}" DisplayMemberPath="FullName" materialDesign:HintAssist.Hint="Исполнитель" IsEnabled="{Binding CanManage}" Margin="0,0,0,10" /><DatePicker Grid.Row="4" Grid.Column="0" SelectedDate="{Binding Deadline}" materialDesign:HintAssist.Hint="Дедлайн" IsEnabled="{Binding CanManage}" Margin="0,0,0,10" /><ComboBox Grid.Row="4" Grid.Column="2" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" materialDesign:HintAssist.Hint="Статус" IsEnabled="{Binding CanChangeStatus}" Margin="0,0,0,10" /><TextBox Grid.Row="5" Grid.ColumnSpan="3" Text="{Binding SaveComment}" materialDesign:HintAssist.Hint="Комментарий" /></Grid></ScrollViewer></TabItem>
            <TabItem Header="История"><DataGrid ItemsSource="{Binding History}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,12"><DataGrid.Columns><DataGridTextColumn Header="Дата" Binding="{Binding ChangedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="140" /><DataGridTextColumn Header="Автор" Binding="{Binding ChangedByName}" Width="150" /><DataGridTextColumn Header="Было" Binding="{Binding OldStatus}" Width="100" /><DataGridTextColumn Header="Стало" Binding="{Binding NewStatus}" Width="100" /><DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*" /></DataGrid.Columns></DataGrid></TabItem>
        </TabControl>
        <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource BorderCBrush}" BorderThickness="0,1,0,0" Padding="24,12"><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Отмена" Command="{Binding CloseCommand}" Margin="0,0,8,0" /><Button Content="Принять в работу" Command="{Binding AcceptCommand}" Background="#2E7D32" Foreground="White" BorderThickness="0" Visibility="{Binding CanAccept, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,8,0" /><Button Content="Отклонить" Command="{Binding RejectCommand}" Foreground="#C62828" Visibility="{Binding CanManage, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,8,0" /><Button Content="Сохранить" Command="{Binding SaveCommand}" IsEnabled="{Binding CanSave}" Background="{StaticResource AccentBlueBrush}" Foreground="White" /></StackPanel></Border>
        <materialDesign:Snackbar MessageQueue="{Binding MessageQueue}" />
    </DockPanel>
</UserControl>
