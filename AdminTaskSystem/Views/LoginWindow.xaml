<Window x:Class="AdminTaskSystem.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:AdminTaskSystem.ViewModels"
        Title="AdminTaskSystem"
        Width="460"
        Height="560"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">
    <Window.DataContext>
        <vm:LoginViewModel />
    </Window.DataContext>

    <Border Background="White"
            CornerRadius="18"
            BorderBrush="#DDE3EC"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="170" />
                <RowDefinition Height="*" />
                <RowDefinition Height="48" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#1565C0"
                    CornerRadius="18,18,0,0"
                    Padding="34,28">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Width="32"
                            Height="32"
                            Command="ApplicationCommands.Close"
                            Click="CloseButton_OnClick"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            ToolTip="Закрыть">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                    <StackPanel>
                        <Border Width="58"
                                Height="58"
                                CornerRadius="14"
                                Background="White"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Domain"
                                                     Width="30"
                                                     Height="30"
                                                     Foreground="#1565C0"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="AdminTaskSystem"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Информационная система администрации"
                                   Foreground="#D8E8FF"
                                   FontSize="12"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="34,30,34,0">
                <TextBlock Text="Вход в систему"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <TextBlock Text="Введите учетные данные сотрудника"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           Margin="0,0,0,22" />

                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Email"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"
                         Height="54"
                         Margin="0,0,0,16" />

                <PasswordBox x:Name="PasswordBox"
                             PasswordChanged="PasswordBox_OnPasswordChanged"
                             materialDesign:HintAssist.Hint="Пароль"
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="LockOutline"
                             Height="54"
                             Margin="0,0,0,10" />

                <Border Background="#FFEBEE"
                        BorderBrush="#FFCDD2"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10,8"
                        Margin="0,0,0,12"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                 Foreground="#C62828"
                                                 Width="18"
                                                 Height="18"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#C62828"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ProgressBar Height="3"
                             IsIndeterminate="True"
                             Margin="0,0,0,14"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Button Command="{Binding LoginCommand}"
                        Height="46"
                        Background="#1565C0"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="LoginVariant"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Войти в систему" Foreground="White" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border Grid.Row="2"
                    BorderBrush="#DDE3EC"
                    BorderThickness="0,1,0,0">
                <TextBlock Text="Версия 1.0 - .NET 10"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Border>
</Window>
