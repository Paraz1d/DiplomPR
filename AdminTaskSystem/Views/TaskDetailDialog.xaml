<UserControl x:Class="AdminTaskSystem.Views.TaskDetailDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" Width="620" Background="White"><DockPanel><Border DockPanel.Dock="Top" Background="{StaticResource AccentBlueBrush}" Padding="24,16"><DockPanel><Button DockPanel.Dock="Right" Content="✕" Command="{Binding CloseCommand}" Background="Transparent" Foreground="White" BorderThickness="0" /><TextBlock Text="{Binding HeaderTitle}" Foreground="White" FontSize="16" FontWeight="SemiBold" /></DockPanel></Border><Grid Margin="24"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBox Text="{Binding TaskTitle}" materialDesign:HintAssist.Hint="Название *" IsEnabled="{Binding CanManage}" Margin="0,0,0,10" /><TextBox Grid.Row="1" Text="{Binding Description}" materialDesign:HintAssist.Hint="Описание" IsEnabled="{Binding CanManage}" Height="70" AcceptsReturn="True" Margin="0,0,0,10" /><ComboBox Grid.Row="2" ItemsSource="{Binding Tickets}" SelectedItem="{Binding SelectedTicket}" DisplayMemberPath="Title" materialDesign:HintAssist.Hint="Заявка" IsEnabled="{Binding CanManage}" Margin="0,0,0,10" /><ComboBox Grid.Row="3" ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}" DisplayMemberPath="FullName" materialDesign:HintAssist.Hint="Исполнитель" IsEnabled="{Binding CanManage}" Margin="0,0,0,10" /><DatePicker Grid.Row="4" SelectedDate="{Binding Deadline}" materialDesign:HintAssist.Hint="Дедлайн" IsEnabled="{Binding CanManage}" Margin="0,0,0,10" /><ComboBox Grid.Row="5" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" materialDesign:HintAssist.Hint="Статус" IsEnabled="{Binding CanChangeStatus}" /></Grid><Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource BorderCBrush}" BorderThickness="0,1,0,0" Padding="24,12"><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Отмена" Command="{Binding CloseCommand}" Margin="0,0,8,0" /><Button Content="Сохранить" Command="{Binding SaveCommand}" Background="{StaticResource AccentBlueBrush}" Foreground="White" /></StackPanel></Border><materialDesign:Snackbar MessageQueue="{Binding MessageQueue}" /></DockPanel></UserControl>
