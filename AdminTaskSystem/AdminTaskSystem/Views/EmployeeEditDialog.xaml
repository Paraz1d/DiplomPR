<UserControl x:Class="AdminTaskSystem.Views.EmployeeEditDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="520">
    <StackPanel Margin="24">
        <TextBlock Text="Карточка сотрудника" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />
        <TextBox Text="{Binding EditEmployee.FullName, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="ФИО *"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,10" />
        <TextBox Text="{Binding EditEmployee.Email, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Email *"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,10" />
        <TextBox Text="{Binding EditEmployee.Phone, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Телефон"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,10" />
        <ComboBox ItemsSource="{Binding Departments}" SelectedValue="{Binding EditEmployee.DepartmentId}" SelectedValuePath="Id" DisplayMemberPath="Name"
                  materialDesign:HintAssist.Hint="Отдел" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,10" />
        <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding EditEmployee.Role}" materialDesign:HintAssist.Hint="Роль"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,10" />
        <TextBox Text="{Binding EditEmployee.Password, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Пароль *"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,10" />
        <CheckBox Content="Активен" IsChecked="{Binding EditEmployee.IsActive}" Margin="0,0,0,16" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Command="{Binding CancelEditCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0" />
            <Button Content="Сохранить" Command="{Binding SaveCommand}" Style="{StaticResource MaterialDesignRaisedButton}" />
        </StackPanel>
    </StackPanel>
</UserControl>
