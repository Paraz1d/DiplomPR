<UserControl x:Class="AdminTaskSystem.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:AdminTaskSystem.Infrastructure"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             infra:EventCommandBehavior.LoadedCommand="{Binding LoadCommand}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,16">
            <TextBlock Text="Отчеты" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <DatePicker SelectedDate="{Binding DateFrom}" materialDesign:HintAssist.Hint="С" Style="{StaticResource MaterialDesignOutlinedDatePicker}" Width="150" Margin="0,0,8,0" />
                <DatePicker SelectedDate="{Binding DateTo}" materialDesign:HintAssist.Hint="По" Style="{StaticResource MaterialDesignOutlinedDatePicker}" Width="150" Margin="0,0,8,0" />
                <Button Content="Обновить" Command="{Binding LoadCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" />
            </StackPanel>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
            <materialDesign:Card Margin="0,0,12,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="Total tickets" Foreground="#607D8B" />
                    <TextBlock Text="{Binding TotalTickets}" FontSize="26" FontWeight="SemiBold" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="0,0,12,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="Done" Foreground="#607D8B" />
                    <TextBlock Text="{Binding DoneTickets}" FontSize="26" FontWeight="SemiBold" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="0,0,12,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="Overdue" Foreground="#607D8B" />
                    <TextBlock Text="{Binding OverdueTickets}" FontSize="26" FontWeight="SemiBold" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Padding="16">
                <StackPanel>
                    <TextBlock Text="Avg close time" Foreground="#607D8B" />
                    <TextBlock Text="{Binding AvgCloseHours, StringFormat={}{0:N1} ч}" FontSize="26" FontWeight="SemiBold" />
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <TabControl Grid.Row="2">
            <TabItem Header="По отделам">
                <DataGrid ItemsSource="{Binding DepartmentStats}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,16,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Отдел" Binding="{Binding Department}" Width="2*" />
                        <DataGridTextColumn Header="Всего" Binding="{Binding Total}" Width="*" />
                        <DataGridTextColumn Header="Новые" Binding="{Binding NewCount}" Width="*" />
                        <DataGridTextColumn Header="В работе" Binding="{Binding InProgressCount}" Width="*" />
                        <DataGridTextColumn Header="Готово" Binding="{Binding DoneCount}" Width="*" />
                        <DataGridTextColumn Header="Просрочено" Binding="{Binding OverdueCount}" Width="*" />
                        <DataGridTextColumn Header="Среднее закрытие, ч" Binding="{Binding AvgCloseHours, StringFormat={}{0:N1}}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="По сотрудникам">
                <DataGrid ItemsSource="{Binding EmployeeStats}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,16,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*" />
                        <DataGridTextColumn Header="Отдел" Binding="{Binding Department}" Width="*" />
                        <DataGridTextColumn Header="Заявок" Binding="{Binding TicketsTotal}" Width="*" />
                        <DataGridTextColumn Header="Заявок готово" Binding="{Binding TicketsDone}" Width="*" />
                        <DataGridTextColumn Header="Заявок просрочено" Binding="{Binding TicketsOverdue}" Width="*" />
                        <DataGridTextColumn Header="Задач" Binding="{Binding TasksTotal}" Width="*" />
                        <DataGridTextColumn Header="Задач готово" Binding="{Binding TasksDone}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
        <materialDesign:Snackbar Grid.Row="2" MessageQueue="{Binding Messages}" VerticalAlignment="Bottom" />
    </Grid>
</UserControl>
