<Window x:Class="AdminTaskSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:AdminTaskSystem.Views"
        xmlns:viewModels="clr-namespace:AdminTaskSystem.ViewModels"
        Title="AdminTaskSystem" Width="1280" Height="780" WindowStartupLocation="CenterScreen"
        Background="#F7F9FC">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:TicketsViewModel}">
            <views:TicketsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:TasksViewModel}">
            <views:TasksView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:EmployeesViewModel}">
            <views:EmployeesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ReportsViewModel}">
            <views:ReportsView />
        </DataTemplate>
    </Window.Resources>

    <materialDesign:DialogHost Identifier="RootDialog">
        <materialDesign:DrawerHost>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.RowSpan="2" Background="#102A43">
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Top" Margin="0,18,0,0">
                            <Button Command="{Binding ShowTicketsCommand}" ToolTip="Заявки" Style="{StaticResource MaterialDesignToolButton}" Foreground="White" Height="58">
                                <StackPanel>
                                    <materialDesign:PackIcon Kind="ClipboardList" Width="24" Height="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="Заявки" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ShowTasksCommand}" ToolTip="Мои задачи" Style="{StaticResource MaterialDesignToolButton}" Foreground="White" Height="58">
                                <StackPanel>
                                    <materialDesign:PackIcon Kind="CheckAll" Width="24" Height="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="Задачи" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ShowEmployeesCommand}" ToolTip="Сотрудники" Style="{StaticResource MaterialDesignToolButton}" Foreground="White" Height="58"
                                    Visibility="{Binding CurrentUser.Role, Converter={StaticResource RoleToVisibilityConverter}, ConverterParameter=admin}">
                                <StackPanel>
                                    <materialDesign:PackIcon Kind="AccountGroup" Width="24" Height="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="Люди" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ShowReportsCommand}" ToolTip="Отчеты" Style="{StaticResource MaterialDesignToolButton}" Foreground="White" Height="58"
                                    Visibility="{Binding CurrentUser.Role, Converter={StaticResource RoleToVisibilityConverter}, ConverterParameter=admin}">
                                <StackPanel>
                                    <materialDesign:PackIcon Kind="ChartBar" Width="24" Height="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="Отчеты" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <Button DockPanel.Dock="Bottom" Command="{Binding LogoutCommand}" ToolTip="Выйти" Style="{StaticResource MaterialDesignToolButton}" Foreground="White" Height="58" Margin="0,0,0,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Logout" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="Выйти" FontSize="11" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Background="White" BorderBrush="#DDE5EE" BorderThickness="0,0,0,1">
                    <DockPanel Margin="24,0">
                        <TextBlock Text="AdminTaskSystem" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUser.FullName}" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <Border Background="#E3F2FD" CornerRadius="4" Padding="8,3">
                                <TextBlock Text="{Binding CurrentUser.Role}" Foreground="#0D47A1" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <ContentControl Grid.Column="1" Grid.Row="1" Content="{Binding CurrentPage}" />
            </Grid>
        </materialDesign:DrawerHost>
    </materialDesign:DialogHost>
</Window>
